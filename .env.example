# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=chess
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=chess_db

# ─── Backend ──────────────────────────────────────────────────────────────────
# In Docker Compose the DATABASE_URL is auto-constructed from POSTGRES_* above
# (see docker-compose.yml → backend → environment). The value below is only
# used when running the backend directly on the host without Docker.
DATABASE_URL=postgresql+asyncpg://chess:change_me_strong_password@localhost:5432/chess_db
REDIS_URL=redis://localhost:6379
SECRET_KEY=change_me_at_least_32_chars_long_here

# ─── ElevenLabs (voice coach Ustaz — backend-only, never expose to client) ───
ELEVENLABS_API_KEY=xi_...
ELEVENLABS_AGENT_ID=agent_...
# Optional: from dashboard URL ?branchid=... — use draft/Main branch; omit for default (published) branch.
# ELEVENLABS_BRANCH_ID=

# ─── Anthropic (text fallback for coach) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Lichess ──────────────────────────────────────────────────────────────────
LICHESS_API_BASE=https://lichess.org

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
# IMPORTANT: NEXT_PUBLIC_* variables are baked into the JS bundle at BUILD time.
# Changing them after build has no effect on the client — rebuild the frontend.
#
# In production behind nginx: leave NEXT_PUBLIC_API_URL empty (browser uses
# same origin, nginx proxies /api → backend). Set a full URL only for
# development or when the API lives on a separate domain.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_ENV=production

# Enable Next.js server-side rewrites /api → backend.
# Needed for: local `npm run dev`, docker-dev. NOT needed in production
# (nginx handles /api proxy), but harmless because nginx intercepts first.
NEXT_PUBLIC_USE_API_REWRITE=1
# Internal backend address for Next.js rewrites inside Docker network.
BACKEND_INTERNAL_URL=http://backend:8000

# ─── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=space-chess.agartu.space
